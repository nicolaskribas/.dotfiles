# vim: ft=systemd

[Unit]
Description=Containerized LanguageTool HTTP server

[Container]
Image=docker.io/meyay/languagetool:latest
AutoUpdate=registry

DropCapability=all
NoNewPrivileges=true
UserNS=keep-id
ReadOnly=true

Tmpfs=/tmp:exec
Volume=languagetool-fasttext:/fasttext:U

PublishPort=0.0.0.0:8081:8081/tcp

PodmanArgs=--cpus=1

[Service]
Restart=on-failure

[Install]
WantedBy=default.target

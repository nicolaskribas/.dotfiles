output HDMI-A-1 {
	scale 1
	position 0,0
	alias $hdmi
}

output eDP-1 {
	scale 1.5
	position 1920,360
	alias $laptop
}

profile laptop {
	output $laptop enable
}

profile extended {
	output $laptop enable
	output $hdmi enable
}

profile external {
	output $laptop disable
	output $hdmi enable
}

profile above {
	output $laptop {
		enable
		position 320,1080
	}
	output $hdmi enable
}
